{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull --ff-only origin main 2>/dev/null || true",
            "statusMessage": "Syncing latest CLAUDE.md from main…",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
